# ============================================================
# llm-safety-gating — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your keys
#   source .env   (or use: pip install python-dotenv and load in code)
# ============================================================

# ── OpenAI ──────────────────────────────────────────────────
# Required for --provider openai
OPENAI_API_KEY=sk-...

# Optional: restrict to a specific organization
# OPENAI_ORG_ID=org-...

# Optional: override base URL (for Azure OpenAI or a proxy)
# OPENAI_BASE_URL=https://your-azure-endpoint.openai.azure.com/

# ── Anthropic ───────────────────────────────────────────────
# Required for --provider anthropic
# Install first: pip install anthropic>=0.25.0
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override base URL (for proxies)
# ANTHROPIC_BASE_URL=https://your-proxy.example.com/

# ── Logging ─────────────────────────────────────────────────
# Set to DEBUG for verbose output, WARNING to quiet things down
# LOG_LEVEL=INFO
